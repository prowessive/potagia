{
    "tables": {
        "users": {
            "description": "System users table",
            "columns": {
                "id": {
                    "type": "UUID",
                    "primary_key": true,
                    "description": "Unique user identifier"
                },
                "username": {
                    "type": "VARCHAR(255)",
                    "unique": true,
                    "not_null": true,
                    "description": "Unique username"
                },
                "email": {
                    "type": "VARCHAR(255)",
                    "unique": true,
                    "not_null": true,
                    "description": "User email address"
                },
                "password_hash": {
                    "type": "VARCHAR(255)",
                    "not_null": true,
                    "description": "User password hash"
                },
                "is_active": {
                    "type": "BOOLEAN",
                    "default": true,
                    "description": "Indicates if the user is active"
                },
                "created_at": {
                    "type": "TIMESTAMP",
                    "default": "CURRENT_TIMESTAMP",
                    "description": "User creation date"
                },
                "updated_at": {
                    "type": "TIMESTAMP",
                    "default": "CURRENT_TIMESTAMP",
                    "description": "Last update date"
                }
            },
            "indexes": [
                {
                    "name": "idx_users_username",
                    "columns": [
                        "username"
                    ]
                },
                {
                    "name": "idx_users_email",
                    "columns": [
                        "email"
                    ]
                }
            ]
        },
        "roles": {
            "description": "System roles table",
            "columns": {
                "id": {
                    "type": "UUID",
                    "primary_key": true,
                    "description": "Unique role identifier"
                },
                "name": {
                    "type": "VARCHAR(100)",
                    "unique": true,
                    "not_null": true,
                    "description": "Role name"
                },
                "description": {
                    "type": "TEXT",
                    "description": "Role description"
                },
                "created_at": {
                    "type": "TIMESTAMP",
                    "default": "CURRENT_TIMESTAMP",
                    "description": "Role creation date"
                },
                "updated_at": {
                    "type": "TIMESTAMP",
                    "default": "CURRENT_TIMESTAMP",
                    "description": "Last update date"
                }
            },
            "indexes": [
                {
                    "name": "idx_roles_name",
                    "columns": [
                        "name"
                    ]
                }
            ]
        },
        "permissions": {
            "description": "System permissions table",
            "columns": {
                "id": {
                    "type": "UUID",
                    "primary_key": true,
                    "description": "Unique permission identifier"
                },
                "name": {
                    "type": "VARCHAR(100)",
                    "unique": true,
                    "not_null": true,
                    "description": "Permission name"
                },
                "resource": {
                    "type": "VARCHAR(100)",
                    "not_null": true,
                    "description": "Resource to which the permission applies"
                },
                "action": {
                    "type": "VARCHAR(50)",
                    "not_null": true,
                    "description": "Allowed action (create, read, update, delete, etc.)"
                },
                "description": {
                    "type": "TEXT",
                    "description": "Permission description"
                },
                "created_at": {
                    "type": "TIMESTAMP",
                    "default": "CURRENT_TIMESTAMP",
                    "description": "Permission creation date"
                }
            },
            "indexes": [
                {
                    "name": "idx_permissions_name",
                    "columns": [
                        "name"
                    ]
                },
                {
                    "name": "idx_permissions_resource_action",
                    "columns": [
                        "resource",
                        "action"
                    ]
                }
            ]
        },
        "user_roles": {
            "description": "Many-to-many relationship table between users and roles",
            "columns": {
                "id": {
                    "type": "UUID",
                    "primary_key": true,
                    "description": "Unique relationship identifier"
                },
                "user_id": {
                    "type": "UUID",
                    "not_null": true,
                    "foreign_key": {
                        "table": "users",
                        "column": "id",
                        "on_delete": "CASCADE"
                    },
                    "description": "Reference to user"
                },
                "role_id": {
                    "type": "UUID",
                    "not_null": true,
                    "foreign_key": {
                        "table": "roles",
                        "column": "id",
                        "on_delete": "CASCADE"
                    },
                    "description": "Reference to role"
                },
                "assigned_at": {
                    "type": "TIMESTAMP",
                    "default": "CURRENT_TIMESTAMP",
                    "description": "Role assignment date"
                },
                "assigned_by": {
                    "type": "UUID",
                    "foreign_key": {
                        "table": "users",
                        "column": "id",
                        "on_delete": "SET NULL"
                    },
                    "description": "User who assigned the role"
                }
            },
            "indexes": [
                {
                    "name": "idx_user_roles_user_id",
                    "columns": [
                        "user_id"
                    ]
                },
                {
                    "name": "idx_user_roles_role_id",
                    "columns": [
                        "role_id"
                    ]
                }
            ],
            "unique_constraints": [
                {
                    "name": "unique_user_role",
                    "columns": [
                        "user_id",
                        "role_id"
                    ]
                }
            ]
        },
        "role_permissions": {
            "description": "Many-to-many relationship table between roles and permissions",
            "columns": {
                "id": {
                    "type": "UUID",
                    "primary_key": true,
                    "description": "Unique relationship identifier"
                },
                "role_id": {
                    "type": "UUID",
                    "not_null": true,
                    "foreign_key": {
                        "table": "roles",
                        "column": "id",
                        "on_delete": "CASCADE"
                    },
                    "description": "Reference to role"
                },
                "permission_id": {
                    "type": "UUID",
                    "not_null": true,
                    "foreign_key": {
                        "table": "permissions",
                        "column": "id",
                        "on_delete": "CASCADE"
                    },
                    "description": "Reference to permission"
                },
                "granted_at": {
                    "type": "TIMESTAMP",
                    "default": "CURRENT_TIMESTAMP",
                    "description": "Permission grant date"
                }
            },
            "indexes": [
                {
                    "name": "idx_role_permissions_role_id",
                    "columns": [
                        "role_id"
                    ]
                },
                {
                    "name": "idx_role_permissions_permission_id",
                    "columns": [
                        "permission_id"
                    ]
                }
            ],
            "unique_constraints": [
                {
                    "name": "unique_role_permission",
                    "columns": [
                        "role_id",
                        "permission_id"
                    ]
                }
            ]
        },
        "user_sessions": {
            "description": "User sessions table (optional, for auditing)",
            "columns": {
                "id": {
                    "type": "UUID",
                    "primary_key": true,
                    "description": "Unique session identifier"
                },
                "user_id": {
                    "type": "UUID",
                    "not_null": true,
                    "foreign_key": {
                        "table": "users",
                        "column": "id",
                        "on_delete": "CASCADE"
                    },
                    "description": "Reference to user"
                },
                "token": {
                    "type": "VARCHAR(255)",
                    "unique": true,
                    "not_null": true,
                    "description": "Session token"
                },
                "ip_address": {
                    "type": "VARCHAR(45)",
                    "description": "User IP address"
                },
                "user_agent": {
                    "type": "TEXT",
                    "description": "Browser user agent"
                },
                "created_at": {
                    "type": "TIMESTAMP",
                    "default": "CURRENT_TIMESTAMP",
                    "description": "Session creation date"
                },
                "expires_at": {
                    "type": "TIMESTAMP",
                    "not_null": true,
                    "description": "Session expiration date"
                },
                "is_active": {
                    "type": "BOOLEAN",
                    "default": true,
                    "description": "Indicates if the session is active"
                }
            },
            "indexes": [
                {
                    "name": "idx_sessions_user_id",
                    "columns": [
                        "user_id"
                    ]
                },
                {
                    "name": "idx_sessions_token",
                    "columns": [
                        "token"
                    ]
                }
            ]
        },
        "audit_logs": {
            "description": "System actions audit table",
            "columns": {
                "id": {
                    "type": "UUID",
                    "primary_key": true,
                    "description": "Unique log identifier"
                },
                "user_id": {
                    "type": "UUID",
                    "foreign_key": {
                        "table": "users",
                        "column": "id",
                        "on_delete": "SET NULL"
                    },
                    "description": "User who performed the action"
                },
                "action": {
                    "type": "VARCHAR(100)",
                    "not_null": true,
                    "description": "Action performed"
                },
                "resource": {
                    "type": "VARCHAR(100)",
                    "description": "Affected resource"
                },
                "resource_id": {
                    "type": "UUID",
                    "description": "Affected resource ID"
                },
                "status": {
                    "type": "VARCHAR(50)",
                    "description": "Action status (success, failed, etc.)"
                },
                "ip_address": {
                    "type": "VARCHAR(45)",
                    "description": "IP address from which the action was performed"
                },
                "details": {
                    "type": "JSONB",
                    "description": "Additional details in JSON format"
                },
                "created_at": {
                    "type": "TIMESTAMP",
                    "default": "CURRENT_TIMESTAMP",
                    "description": "Action date"
                }
            },
            "indexes": [
                {
                    "name": "idx_audit_logs_user_id",
                    "columns": [
                        "user_id"
                    ]
                },
                {
                    "name": "idx_audit_logs_action",
                    "columns": [
                        "action"
                    ]
                },
                {
                    "name": "idx_audit_logs_created_at",
                    "columns": [
                        "created_at"
                    ]
                }
            ]
        },
        "documents": {
            "description": "Documents table containing web pages, images, and video files",
            "columns": {
                "id": {
                    "type": "UUID",
                    "primary_key": true,
                    "description": "Unique document identifier"
                },
                "title": {
                    "type": "VARCHAR(255)",
                    "not_null": true,
                    "description": "Document title"
                },
                "type": {
                    "type": "VARCHAR(50)",
                    "not_null": true,
                    "description": "Document type (webpage, image, video)"
                },
                "file_path": {
                    "type": "TEXT",
                    "description": "File system path or URL"
                },
                "content": {
                    "type": "BYTEA",
                    "description": "File content stored as binary data"
                },
                "mime_type": {
                    "type": "VARCHAR(100)",
                    "description": "MIME type of the document"
                },
                "file_size": {
                    "type": "BIGINT",
                    "description": "File size in bytes"
                },
                "metadata": {
                    "type": "JSONB",
                    "description": "Additional metadata in JSON format"
                },
                "created_by": {
                    "type": "UUID",
                    "foreign_key": {
                        "table": "users",
                        "column": "id",
                        "on_delete": "SET NULL"
                    },
                    "description": "User who created the document"
                },
                "created_at": {
                    "type": "TIMESTAMP",
                    "default": "CURRENT_TIMESTAMP",
                    "description": "Document creation date"
                },
                "updated_at": {
                    "type": "TIMESTAMP",
                    "default": "CURRENT_TIMESTAMP",
                    "description": "Last update date"
                }
            },
            "indexes": [
                {
                    "name": "idx_documents_type",
                    "columns": [
                        "type"
                    ]
                },
                {
                    "name": "idx_documents_created_by",
                    "columns": [
                        "created_by"
                    ]
                },
                {
                    "name": "idx_documents_created_at",
                    "columns": [
                        "created_at"
                    ]
                }
            ]
        },
        "paths": {
            "description": "Route paths table for web page management",
            "columns": {
                "id": {
                    "type": "UUID",
                    "primary_key": true,
                    "description": "Unique path identifier"
                },
                "path": {
                    "type": "VARCHAR(500)",
                    "unique": true,
                    "not_null": true,
                    "description": "URL path"
                },
                "document_id": {
                    "type": "UUID",
                    "foreign_key": {
                        "table": "documents",
                        "column": "id",
                        "on_delete": "CASCADE"
                    },
                    "description": "Reference to document"
                },
                "permission_id": {
                    "type": "UUID",
                    "foreign_key": {
                        "table": "permissions",
                        "column": "id",
                        "on_delete": "SET NULL"
                    },
                    "description": "Reference to required permission"
                },
                "is_active": {
                    "type": "BOOLEAN",
                    "default": true,
                    "description": "Indicates if the path is active"
                },
                "metadata": {
                    "type": "JSONB",
                    "description": "Additional path metadata in JSON format"
                },
                "created_at": {
                    "type": "TIMESTAMP",
                    "default": "CURRENT_TIMESTAMP",
                    "description": "Path creation date"
                },
                "updated_at": {
                    "type": "TIMESTAMP",
                    "default": "CURRENT_TIMESTAMP",
                    "description": "Last update date"
                }
            },
            "indexes": [
                {
                    "name": "idx_paths_path",
                    "columns": [
                        "path"
                    ]
                },
                {
                    "name": "idx_paths_document_id",
                    "columns": [
                        "document_id"
                    ]
                },
                {
                    "name": "idx_paths_permission_id",
                    "columns": [
                        "permission_id"
                    ]
                }
            ]
        }
    }
}